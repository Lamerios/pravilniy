# ===================================================================
# Quiz Game - Environment Configuration (Root)
# ===================================================================
# Скопируйте этот файл в .env и настройте под ваше окружение
# Этот файл содержит общие настройки для всего проекта

# === Environment Settings ===
NODE_ENV=development
APP_ENV=local
APP_NAME=quiz-game
APP_VERSION=1.0.0

# === Database Configuration (PostgreSQL) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quiz_game_dev
DB_USER=postgres
DB_PASSWORD=Lamerios7891
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# === Cache Configuration (Redis) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# === Backend API Configuration ===
BACKEND_PORT=5001
BACKEND_HOST=localhost
API_PREFIX=/api
API_VERSION=v1

# === Frontend Configuration ===
FRONTEND_PORT=3000
FRONTEND_HOST=localhost

# === Authentication & Security ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-change-in-production
BCRYPT_ROUNDS=12

# === CORS Configuration ===
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# === File Upload ===
UPLOAD_MAX_SIZE=10mb
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf

# === Logging ===
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10mb
LOG_MAX_FILES=5

# === Rate Limiting ===
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# === WebSocket ===
WS_PORT=5002
WS_PATH=/socket.io

# === External Services ===
# Email Service (будет настроено позже)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@quiz-game.com

# Notification Services (будет настроено позже)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# === Monitoring & Analytics ===
# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Google Analytics (будет настроено позже)
GA_TRACKING_ID=

# === Development Tools ===
# Hot Reload
HOT_RELOAD=true
BROWSER_SYNC=true

# Debug
DEBUG=quiz-game:*
VERBOSE=false

# === Docker Configuration ===
COMPOSE_PROJECT_NAME=quiz-game
COMPOSE_FILE=docker-compose.yml

# === Backup Configuration ===
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# === Feature Flags ===
FEATURE_WEBSOCKET_REALTIME=true
FEATURE_FILE_UPLOAD=true
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_ANALYTICS=false

# ===================================================================
# Production Overrides (не используйте эти значения в production!)
# ===================================================================
# В production обязательно измените:
# - JWT_SECRET (минимум 32 символа, случайная строка)
# - SESSION_SECRET (случайная строка)
# - DB_PASSWORD (сложный пароль)
# - REDIS_PASSWORD (если используется)
# - Все внешние сервисы (SMTP, Sentry, etc.)
# ===================================================================
