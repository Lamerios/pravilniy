# ===================================================================
# Quiz Game Backend - Environment Configuration
# ===================================================================
# Скопируйте этот файл в .env и настройте под ваше окружение
# Переменные из корневого .env файла имеют приоритет

# === Server Configuration ===
PORT=5001
HOST=localhost
NODE_ENV=development

# === Database Configuration (PostgreSQL) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quiz_game_dev
DB_USER=quiz_user
DB_PASSWORD=dev_password
DB_SSL=false
DB_SCHEMA=quiz_app

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# === Cache Configuration (Redis) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
REDIS_KEY_PREFIX=quiz_game:

# === Authentication & Security ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=quiz-game-api
JWT_AUDIENCE=quiz-game-client

# Password Hashing
BCRYPT_ROUNDS=12

# Session Management
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000
SESSION_SECURE=false

# === API Configuration ===
API_PREFIX=/api
API_VERSION=v1
API_TIMEOUT=30000

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# === File Upload ===
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads
UPLOAD_TEMP_PATH=./temp
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
MAX_FILES_PER_UPLOAD=5

# === Logging Configuration ===
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/backend.log
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_MAX_FILES=5
LOG_CONSOLE_ENABLED=true

# === WebSocket Configuration ===
WS_ENABLED=true
WS_PORT=5002
WS_PATH=/socket.io
WS_CORS_ORIGIN=http://localhost:3000
WS_MAX_CONNECTIONS=1000

# === Database Migrations ===
DB_MIGRATE_AUTO=false
DB_SEED_AUTO=false
DB_SYNC_FORCE=false

# === External Services ===
# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Quiz Game <noreply@quiz-game.com>

# === Monitoring & Error Tracking ===
# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACE_SAMPLE_RATE=1.0

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# === Performance ===
# Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# Request Timeout
REQUEST_TIMEOUT=30000
KEEP_ALIVE_TIMEOUT=5000

# === Security Headers ===
HELMET_ENABLED=true
HELMET_CSP_ENABLED=false
HELMET_HSTS_ENABLED=true

# === Game Configuration ===
# Game Settings
MAX_TEAMS_PER_GAME=20
MAX_ROUNDS_PER_GAME=10
MAX_QUESTIONS_PER_ROUND=20
GAME_SESSION_TIMEOUT=7200000

# Scoring
DEFAULT_QUESTION_POINTS=10
MAX_STAKE_MULTIPLIER=3
MIN_STAKE_MULTIPLIER=0.5

# === Development Tools ===
# Hot Reload
HOT_RELOAD=true
WATCH_FILES=true

# Debug
DEBUG=quiz-game:backend:*
DEBUG_SQL=false
VERBOSE_LOGGING=false

# === Testing ===
TEST_DB_NAME=quiz_game_test
TEST_TIMEOUT=30000
TEST_COVERAGE_THRESHOLD=80

# === Backup & Maintenance ===
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance

# ===================================================================
# Production Security Checklist
# ===================================================================
# В production обязательно:
# ✓ Измените JWT_SECRET (минимум 32 символа)
# ✓ Измените SESSION_SECRET
# ✓ Установите сложный DB_PASSWORD
# ✓ Настройте REDIS_PASSWORD
# ✓ Установите NODE_ENV=production
# ✓ Отключите DEBUG режимы
# ✓ Настройте SENTRY_DSN
# ✓ Установите CORS_ORIGIN на production домен
# ✓ Включите SESSION_SECURE=true для HTTPS
# ✓ Настройте реальные SMTP настройки
# ===================================================================
