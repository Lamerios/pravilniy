{
  "name": "quiz-game-backend",
  "version": "1.0.0",
  "description": "Quiz Game Backend - Node.js + TypeScript + Express",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "server": "ts-node src/server.ts",
    "test:server": "ts-node src/server-test.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "lint:check": "eslint src --ext .ts,.js --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:watch": "jest --coverage --watch",
    "test:coverage:ci": "jest --coverage --ci --coverageReporters=text-lcov --coverageReporters=html",
    "coverage:open": "open coverage/lcov-report/index.html",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "validate": "npm run type-check && npm run lint:check && npm run format:check",
    "db:init": "ts-node src/database/init.ts",
    "migrate:up": "ts-node src/database/migrate.ts up",
    "migrate:down": "ts-node src/database/migrate.ts down",
    "migrate:reset": "ts-node src/database/migrate.ts reset",
    "db:seed": "ts-node src/database/seed.ts",
    "db:seed:basic": "ts-node src/database/seed.ts basic",
    "db:seed:demo": "ts-node src/database/seed.ts demo",
    "db:seed:full": "ts-node src/database/seed.ts full",
    "db:setup": "ts-node src/database/setup.ts",
    "db:setup:basic": "ts-node src/database/setup.ts basic",
    "db:setup:demo": "ts-node src/database/setup.ts demo",
    "db:setup:full": "ts-node src/database/setup.ts full",
    "db:reset": "ts-node src/database/reset.ts",
    "db:reset:force": "ts-node src/database/reset.ts --force",
    "db:clean": "ts-node src/database/clean.ts",
    "db:clean:force": "ts-node src/database/clean.ts --force",
    "db:clean:reseed": "ts-node src/database/clean.ts --force --reseed",
    "db:check": "ts-node src/database/check.ts"
  },
  "keywords": [
    "quiz",
    "game",
    "backend",
    "nodejs",
    "typescript",
    "express",
    "postgresql",
    "sequelize"
  ],
  "author": "Quiz Game Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/socket.io": "^3.0.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.2.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.1",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.7",
    "sequelize": "^6.32.1",
    "sequelize-typescript": "^2.1.5",
    "socket.io": "^4.8.1",
    "tslib": "^2.8.1",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.2",
    "@types/pg": "^8.10.2",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.1",
    "sequelize-cli": "^6.6.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,js,json",
    "ignore": [
      "src/**/*.test.ts",
      "src/**/*.spec.ts"
    ],
    "exec": "ts-node src/index.ts"
  }
}
