# ===================================================================
# Quiz Game Docker - Environment Configuration
# ===================================================================
# Конфигурация для Docker Compose окружения
# Скопируйте этот файл в .env в папке docker/

# === Docker Compose ===
COMPOSE_PROJECT_NAME=quiz-game
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROFILES=dev

# === PostgreSQL Database ===
POSTGRES_DB=quiz_game_dev
POSTGRES_USER=quiz_user
POSTGRES_PASSWORD=dev_password
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C
POSTGRES_HOST_AUTH_METHOD=md5

# Database Connection
DB_HOST=postgres
DB_PORT=5432
DB_SSL=false

# === Redis Cache ===
REDIS_PASSWORD=
REDIS_DATABASES=16
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Redis Connection
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# === PgAdmin (Development) ===
PGADMIN_DEFAULT_EMAIL=admin@quiz-game.local
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_CONFIG_SERVER_MODE=False
PGADMIN_LISTEN_PORT=80

# === Redis Commander (Development) ===
REDIS_COMMANDER_PORT=8081
REDIS_HOSTS=local:redis:6379

# === Nginx (Production) ===
NGINX_HOST=quiz-game.local
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=10m

# === SSL Configuration (Production) ===
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
SSL_DHPARAM_PATH=./ssl/dhparam.pem

# === Volumes ===
POSTGRES_DATA_PATH=./volumes/postgres
REDIS_DATA_PATH=./volumes/redis
PGADMIN_DATA_PATH=./volumes/pgadmin
NGINX_LOGS_PATH=./volumes/nginx/logs
APP_UPLOADS_PATH=./volumes/uploads
APP_LOGS_PATH=./volumes/logs

# === Network ===
NETWORK_NAME=quiz-network
NETWORK_DRIVER=bridge

# === Backend Service ===
BACKEND_IMAGE=quiz-game-backend:latest
BACKEND_PORT=5001
BACKEND_REPLICAS=1

# === Frontend Service ===
FRONTEND_IMAGE=quiz-game-frontend:latest
FRONTEND_PORT=3000
FRONTEND_REPLICAS=1

# === Health Checks ===
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=60s

# === Resource Limits ===
# PostgreSQL
POSTGRES_MEMORY_LIMIT=1g
POSTGRES_MEMORY_RESERVATION=512m
POSTGRES_CPU_LIMIT=1.0

# Redis
REDIS_MEMORY_LIMIT=512m
REDIS_MEMORY_RESERVATION=256m
REDIS_CPU_LIMIT=0.5

# Backend
BACKEND_MEMORY_LIMIT=1g
BACKEND_MEMORY_RESERVATION=512m
BACKEND_CPU_LIMIT=1.0

# Frontend
FRONTEND_MEMORY_LIMIT=512m
FRONTEND_MEMORY_RESERVATION=256m
FRONTEND_CPU_LIMIT=0.5

# === Logging ===
LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# === Restart Policies ===
RESTART_POLICY=unless-stopped

# === Development Overrides ===
# Для development окружения
DEV_POSTGRES_PORT=5432
DEV_REDIS_PORT=6379
DEV_PGADMIN_PORT=8080
DEV_REDIS_COMMANDER_PORT=8081

# === Production Overrides ===
# Для production окружения
PROD_POSTGRES_PASSWORD=your-strong-production-password
PROD_REDIS_PASSWORD=your-redis-production-password
PROD_PGADMIN_EMAIL=admin@yourdomain.com
PROD_PGADMIN_PASSWORD=your-strong-admin-password

# === Backup Configuration ===
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# === Monitoring ===
MONITORING_ENABLED=false
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# === Environment Specific ===
# Development
ENVIRONMENT=development
DEBUG=true
HOT_RELOAD=true

# Staging
# ENVIRONMENT=staging
# DEBUG=false
# HOT_RELOAD=false

# Production
# ENVIRONMENT=production
# DEBUG=false
# HOT_RELOAD=false
# SSL_ENABLED=true

# ===================================================================
# Security Notes for Production
# ===================================================================
# В production обязательно:
# ✓ Измените все пароли (POSTGRES_PASSWORD, REDIS_PASSWORD, etc.)
# ✓ Настройте SSL сертификаты
# ✓ Ограничьте доступ к PgAdmin и Redis Commander
# ✓ Настройте firewall правила
# ✓ Используйте secrets для чувствительных данных
# ✓ Регулярно обновляйте Docker образы
# ✓ Настройте мониторинг и алерты
# ===================================================================
