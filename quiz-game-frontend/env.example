# ===================================================================
# Quiz Game Frontend - Environment Configuration
# ===================================================================
# Скопируйте этот файл в .env и настройте под ваше окружение
# Переменные должны начинаться с VITE_ чтобы быть доступными в браузере

# === Development Server ===
PORT=3000
HOST=localhost
HTTPS=false

# === API Configuration ===
VITE_API_URL=http://localhost:5000
VITE_API_PREFIX=/api
VITE_API_VERSION=v1
VITE_API_TIMEOUT=30000

# === WebSocket Configuration ===
VITE_WS_URL=http://localhost:5002
VITE_WS_PATH=/socket.io
VITE_WS_RECONNECT_ATTEMPTS=5
VITE_WS_RECONNECT_DELAY=1000

# === Application Configuration ===
VITE_APP_NAME=Quiz Game
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Система управления интеллектуальными играми
VITE_APP_AUTHOR=Quiz Game Team

# === Environment ===
VITE_NODE_ENV=development
VITE_APP_ENV=local

# === Authentication ===
VITE_JWT_STORAGE_KEY=quiz_game_token
VITE_REFRESH_TOKEN_KEY=quiz_game_refresh_token
VITE_SESSION_TIMEOUT=86400000

# === UI Configuration ===
VITE_THEME_DEFAULT=light
VITE_LANGUAGE_DEFAULT=ru
VITE_TIMEZONE_DEFAULT=Europe/Moscow

# === Features Flags ===
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_SOUND_EFFECTS=true
VITE_FEATURE_ANIMATIONS=true
VITE_FEATURE_KEYBOARD_SHORTCUTS=true
VITE_FEATURE_OFFLINE_MODE=false

# === Performance ===
VITE_ENABLE_PWA=false
VITE_CACHE_STRATEGY=networkFirst
VITE_LAZY_LOADING=true
VITE_IMAGE_OPTIMIZATION=true

# === External Services ===
# Analytics
VITE_GA_TRACKING_ID=
VITE_YANDEX_METRIKA_ID=

# Error Tracking
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Social Auth (будет настроено позже)
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
VITE_GITHUB_CLIENT_ID=

# === File Upload ===
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf
VITE_MAX_FILES_PER_UPLOAD=5

# === Game Configuration ===
VITE_MAX_TEAM_NAME_LENGTH=50
VITE_MAX_ANSWER_LENGTH=500
VITE_AUTO_SAVE_INTERVAL=30000
VITE_SCOREBOARD_REFRESH_INTERVAL=5000

# === Notifications ===
VITE_NOTIFICATION_TIMEOUT=5000
VITE_TOAST_POSITION=top-right
VITE_SOUND_NOTIFICATIONS=true

# === Development Tools ===
VITE_SHOW_DEV_TOOLS=true
VITE_ENABLE_MOCK_DATA=false
VITE_DEBUG_MODE=true
VITE_CONSOLE_LOGS=true

# === Build Configuration ===
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true
VITE_BUILD_ANALYZE=false

# === PWA Configuration (если включено) ===
VITE_PWA_NAME=Quiz Game
VITE_PWA_SHORT_NAME=QuizGame
VITE_PWA_DESCRIPTION=Система управления интеллектуальными играми
VITE_PWA_THEME_COLOR=#000000
VITE_PWA_BACKGROUND_COLOR=#ffffff

# === CDN & Assets ===
VITE_CDN_URL=
VITE_ASSETS_URL=
VITE_STATIC_URL=/static

# === Internationalization ===
VITE_I18N_LOCALE=ru
VITE_I18N_FALLBACK_LOCALE=en
VITE_I18N_AVAILABLE_LOCALES=ru,en

# === Testing ===
VITE_TEST_API_URL=http://localhost:5001
VITE_E2E_BASE_URL=http://localhost:3000

# ===================================================================
# Production Configuration
# ===================================================================
# В production измените:
# ✓ VITE_API_URL на production API URL
# ✓ VITE_WS_URL на production WebSocket URL
# ✓ VITE_NODE_ENV=production
# ✓ VITE_APP_ENV=production
# ✓ Настройте реальные внешние сервисы (GA, Sentry)
# ✓ HTTPS=true для production
# ✓ Отключите VITE_DEBUG_MODE
# ✓ Отключите VITE_SHOW_DEV_TOOLS
# ===================================================================

# ===================================================================
# Environment-specific overrides
# ===================================================================

# Staging
# VITE_API_URL=https://api-staging.quiz-game.com
# VITE_WS_URL=https://ws-staging.quiz-game.com
# VITE_APP_ENV=staging

# Production
# VITE_API_URL=https://api.quiz-game.com
# VITE_WS_URL=https://ws.quiz-game.com
# VITE_APP_ENV=production
# VITE_DEBUG_MODE=false
# VITE_CONSOLE_LOGS=false
# ===================================================================
